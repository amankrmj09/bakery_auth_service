CONFIG_SERVER_URL=http://bakery-config-server:8021
AUTH_DB_URL=jdbc:postgresql://bakery-auth-db:5432/bakery_auth
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=your_auth_db_password
REDIS_HOST=bakery-carts-redis
